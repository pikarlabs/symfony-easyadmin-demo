{% extends 'base.html.twig' %}

{# @var entry entity \App\Entity\Post #}
{# @var entryTag entity \App\Entity\Tags #}

{% block title %}Blog - {{ entry.title }}{% endblock %}


{% block body %}
  {{ dump(entry) }}
<div class="container mx-auto my-5">
    <div class="example-wrapper prose">
        <h1 class="text-2xl">Blog {{ entry.title }}! ✅</h1>
        
        <table class="table table-zebra">
            <tr>
              <th>Title</th>
              <td>
                {{ entry.title }}
              </td>
            </tr>
            <tr>
              <th>Title (ID)</th>
              <td>
                {{ entry.titleId }}
              </td>
            </tr>
            <tr>
              <th>Author</th>
              <td>
                {{ entry.author.fullName }}
              </td>
            </tr>
            <tr>
              <th>Tags</th>
              <td>
                {% for entryTag in entry.tags %}
                  <div class="badge badge-soft badge-primary">
                    {{ entryTag.name }}
                  </div>
                {% endfor %}
              </td>
            </tr>
            <tr>
              <th>Published</th>
              <td>
                {{ entry.publishedAt|date }}
              </td>
            </tr>
            <tr>
              <th>Summary</th>
              <td>
                {{ entry.summary|raw }}
              </td>
            </tr>
            <tr>
              <th>Summary (ID)</th>
              <td>
                {{ entry.summaryId|raw }}
              </td>
            </tr>
            <tr>
              <th>Content</th>
              <td>
                {{ entry.content|raw }}
              </td>
            </tr>
            <tr>
              <th>Content (ID)</th>
              <td>
                {{ entry.contentId|raw }}
              </td>
            </tr>
        </table>
    </div>
</div>
{% endblock %}
