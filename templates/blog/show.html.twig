{% extends 'base.html.twig' %}

{% block title %}Hello BlogController!{% endblock %}

{% block body %}
    <div class="example-wrapper prose">
        <h1 class="text-2xl">Blog {{ entry.title }}! ✅</h1>
        
        <table class="table table-zebra">
            <tr>
              <th>Title</th>
              <th>Summary</th>
              <th>Author</th>
              <th>Tags</th>
              <th>Published</th>
            </tr>
              <tr>
                <td>
                  {{ entry.title }}
                </td>
                <td>
                  {{ entry.summary }}
                </td>
                <td>
                  {{ entry.author.fullName }}
                </td>
                <td>
                  {% for entryChild in entry.tags %}
                    <div class="badge badge-soft badge-primary">
                      {{ entryChild.name }}
                    </div>
                  {% endfor %}
                </td>
                <td>
                  {{ entry.publishedAt|date }}
                </td>
              </tr>
        </table>
    </div>

<style>
    .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
</style>
{% endblock %}
